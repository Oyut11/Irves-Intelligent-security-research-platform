{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "IRVES",
    "version": "1.0.0-alpha",
    "identifier": "com.irves.app",
    "build": {
        "beforeDevCommand": "",
        "devUrl": "http://localhost:8765",
        "beforeBuildCommand": "",
        "frontendDist": "../backend/static"
    },
    "app": {
        "windows": [
            {
                "title": "IRVES — Intelligent Security Tool",
                "width": 1280,
                "height": 820,
                "minWidth": 960,
                "minHeight": 640,
                "resizable": true,
                "fullscreen": false,
                "decorations": true,
                "transparent": false,
                "center": true
            }
        ],
        "security": {
            "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:* https://* wss://*; img-src 'self' data: blob:; font-src 'self' data:; object-src 'none'"
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/128x128.png",
            "icons/128x128@2x.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ]
    }
}