# IRVES Configuration for Docker
# Copy to .env and fill in your values before running: docker compose up -d

# ── App ─────────────────────────────────────────────────────────
APP_NAME=IRVES
DEBUG=false
ENVIRONMENT=production

# ── Database ────────────────────────────────────────────────────
# Option 1: SQLite (default, single-file, no external DB needed)
DATABASE_URL=sqlite+aiosqlite:///./irves.db

# Option 2: PostgreSQL (recommended for production, multi-user)
# Uncomment and use this instead if running postgres service in docker-compose.yml
# DATABASE_URL=postgresql+asyncpg://irves:YOUR_POSTGRES_PASSWORD@postgres:5432/irves
POSTGRES_PASSWORD=irves_secure_pass_change_this

# ── Tool Paths ──────────────────────────────────────────────────
# In Docker, these are pre-installed and available in PATH
APKTOOL_PATH=apktool
JADX_PATH=jadx
FRIDA_PATH=frida
MITMPROXY_PATH=mitmproxy

# ── AI Provider (Required for AI features) ───────────────────────
# Set at least one API key. IRVES supports Anthropic, OpenAI, Gemini,
# xAI, DeepSeek, Together AI, HuggingFace, and Ollama (local).
#
# Use AI_API_KEY for generic routing, or set provider-specific keys below.
AI_API_KEY=your_api_key_here

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_AI_API_KEY=
HUGGINGFACE_API_KEY=

# AI model — format: "provider/model-name" (e.g. "anthropic/claude-3-5-sonnet-20240620")
AI_MODEL=
AI_PROVIDER=

# ── Storage Paths ────────────────────────────────────────────────
# In Docker, these map to volumes defined in docker-compose.yml
PROJECTS_DIR=/app/.irves/projects
REPORTS_DIR=/app/.irves/reports

# ── Server ──────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8765
# Required for OAuth session security. Generate one:
#   python backend/generate_secret.py
# Or: openssl rand -hex 32
SECRET_KEY=change-this-to-a-secure-random-string
REDIRECT_URI=http://localhost:8765/api/auth/callback

# ── Git Integrations (Optional) ─────────────────────────────────
# Create GitHub/GitLab OAuth apps to get these credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITLAB_CLIENT_ID=
GITLAB_SECRET=
