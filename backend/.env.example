# IRVES Configuration
# Copy to .env and fill in your values

# ── App ─────────────────────────────────────────────────────────
APP_NAME=IRVES
DEBUG=false
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./irves.db

# ── Tool Paths ──────────────────────────────────────────────────
# Leave as-is to use system PATH, or specify full paths
APKTOOL_PATH=apktool
JADX_PATH=jadx
FRIDA_PATH=frida
MITMPROXY_PATH=mitmproxy

# ── AI Provider (Required for AI features) ───────────────────────
# Set at least one API key. Supports: Anthropic, OpenAI, Gemini, xAI,
# DeepSeek, Together AI, HuggingFace, and Ollama (local).
AI_API_KEY=your_api_key_here

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
TOGETHER_AI_API_KEY=
HUGGINGFACE_API_KEY=

# AI model — format: "provider/model-name"
AI_MODEL=

# ── Storage Paths ────────────────────────────────────────────────
PROJECTS_DIR=~/.irves/projects
REPORTS_DIR=~/.irves/reports

# ── Server ──────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765
# Set a unique secret for session encryption (OAuth)
SECRET_KEY=change-this-to-a-secure-random-string
REDIRECT_URI=http://127.0.0.1:8765/api/auth/callback

# ── Git Integrations ─────────────────────────────────────────────
# Create a GitHub OAuth App / GitLab Application to get these
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=