# IRVES Configuration
# Copy to .env and fill in your values

# ── App ─────────────────────────────────────────────────────────
APP_NAME=IRVES
DEBUG=false
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./irves.db

# ── Tool Paths ──────────────────────────────────────────────────
# Leave as-is to use system PATH, or specify full paths
APKTOOL_PATH=apktool
JADX_PATH=jadx
FRIDA_PATH=frida
MITMPROXY_PATH=mitmproxy

# ── MobSF (Mobile Security Framework) ───────────────────────────
MOBSF_URL=http://127.0.0.1:8000
MOBSF_API_KEY=your_mobsf_api_key_here

# ── AI (Anthropic Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODEL=claude-sonnet-4-6

# ── Storage Paths ────────────────────────────────────────────────
PROJECTS_DIR=~/.irves/projects
REPORTS_DIR=~/.irves/reports

# ── Server ──────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765