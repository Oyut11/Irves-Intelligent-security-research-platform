# IRVES Configuration
# Copy to .env and fill in your values

# ── App ─────────────────────────────────────────────────────────
APP_NAME=IRVES
DEBUG=false
ENVIRONMENT=development

# ── Database ────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./irves.db

# ── Tool Paths ──────────────────────────────────────────────────
# Leave as-is to use system PATH, or specify full paths
APKTOOL_PATH=apktool
JADX_PATH=jadx
FRIDA_PATH=frida
MITMPROXY_PATH=mitmproxy

# ── AI (Anthropic Claude) ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
AI_MODEL=claude-sonnet-4-6

# ── Storage Paths ────────────────────────────────────────────────
PROJECTS_DIR=~/.irves/projects
REPORTS_DIR=~/.irves/reports

# ── Server ──────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8765
# Set a unique secret for session encryption (OAuth)
SECRET_KEY=change-this-to-a-secure-random-string
REDIRECT_URI=http://127.0.0.1:8765/api/auth/callback

# ── Git Integrations ─────────────────────────────────────────────
# Create a GitHub OAuth App / GitLab Application to get these
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=